# Rapha Lumina - Environment Variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Supabase
VITE_SUPABASE_URL=https://vousucfboetqtppjywlg.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Paystack public key (test or live)
# Get from: https://dashboard.paystack.com/#/settings/developer
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# IMPORTANT: Never put service_role keys, secret keys, or any private
# credentials in this file. Anything prefixed VITE_ is bundled into the
# JavaScript shipped to every browser. Use Supabase Edge Function secrets
# for anything that needs to stay private.
