# Force the canonical domain (apex). Anything hitting www gets a 301 to the bare domain.
# The :splat preserves the rest of the path and query string.
https://www.raphalumina.com/*  https://raphalumina.com/:splat  301!

# SPA fallback. React Router handles routing in the browser, so every unknown path
# should serve index.html instead of 404ing on Cloudflare's edge.
/*  /index.html  200
